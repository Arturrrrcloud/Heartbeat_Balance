<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/calm_background"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gra relaksująca"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/calm_accent"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/txtCalmScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Spokój: 0 / 12"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/txtCalmHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Oddychaj powoli i twórz spokojny ogród."
        android:textSize="13sp"
        android:gravity="center"
        android:textColor="@color/text_hint"
        android:layout_marginBottom="12dp" />

    <FrameLayout
        android:id="@+id/calmGardenArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="300dp"
        android:layout_marginBottom="16dp"
        android:padding="8dp">

        <View
            android:id="@+id/breathCircle"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="center" />

        <TextView
            android:id="@+id/txtBreathPhase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Wdech"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

    </FrameLayout>

    <Button
        android:id="@+id/btnAddCalm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dodaj spokojny element"
        android:textColor="@color/calm_background"
        android:textStyle="bold"
        android:backgroundTint="@color/calm_accent"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btnRestartRelaxGame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Od nowa"
        android:textColor="@color/text_primary"
        android:backgroundTint="@color/calm_surface"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btnBackRelaxGame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Wróć"
        android:backgroundTint="#00000000"
        android:textColor="@color/text_hint" />

</LinearLayout>