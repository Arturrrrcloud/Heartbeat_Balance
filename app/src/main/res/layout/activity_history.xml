<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/calm_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnHistoryBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wróć"
            android:backgroundTint="#00000000"
            android:textColor="@color/text_hint" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Historia"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/calm_accent" />

        <Button
            android:id="@+id/btnClearHistory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Usuń"
            android:backgroundTint="@color/calm_surface"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtAvgBpm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:text="Średnia: -- BPM"
        android:textSize="18sp"
        android:textColor="@color/calm_accent"
        android:gravity="center" />

    <TextView
        android:id="@+id/txtNoData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Brak pomiarów"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:textColor="@color/text_hint"
        android:visibility="gone" />

    <ListView
        android:id="@+id/listHistory"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
